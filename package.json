{
  "name": "react-media-optimizer",
  "version": "1.2.0-beta.1",
  "description": "🚀 AI-Powered React component for auto-optimized images & videos with lazy loading, WebP conversion, SEO metadata, face detection, smart cropping, and auto alt-text generation",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "sideEffects": false,
  "scripts": {
    "dev": "vite",
    "build": "tsup src/index.ts --format cjs,esm --dts --external react,react-dom",
    "type-check": "tsc --noEmit",
    "prepublishOnly": "npm run build",
    "test": "vitest",
    "lint": "eslint src --ext ts,tsx"
  },
  "keywords": [
    "react",
    "image",
    "video",
    "optimization",
    "performance",
    "lazy-load",
    "webp",
    "media",
    "compression",
    "seo",
    "web-vitals",
    "nextjs",
    "gatsby",
    "schema",
    "json-ld",
    "key-moments",
    "video-chapters",
    "ai",
    "face-detection",
    "smart-crop",
    "auto-alt",
    "machine-learning",
    "transformers",
    "mediapipe"
  ],
  "peerDependencies": {
    "react": ">=16.8.0",
    "react-dom": ">=16.8.0"
  },
  "dependencies": {
    "@mediapipe/face_detection": "^0.4.1646425229",
    "@xenova/transformers": "^2.17.2"
  },
  "optionalDependencies": {
    "browser-image-compression": "^2.0.2",
    "sharp": "^0.34.5"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/react": "^18.2.48",
    "@types/react-dom": "^18.2.18",
    "@vitejs/plugin-react": "^4.2.1",
    "tsup": "^8.0.1",
    "typescript": "^5.3.3",
    "vite": "^5.0.12",
    "vitest": "^1.2.2"
  },
  "author": "Yared Abebe",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/yaredabebe/react-media-optimizer.git"
  },
  "bugs": {
    "url": "https://github.com/yaredabebe/react-media-optimizer/issues"
  },
  "homepage": "https://github.com/yaredabebe/react-media-optimizer#readme"
}